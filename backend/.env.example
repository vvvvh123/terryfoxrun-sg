# Local PostgreSQL/default profile
DATABASE_URL=jdbc:postgresql://localhost:5432/terryfoxrun
DATABASE_USERNAME=terryfox
DATABASE_PASSWORD=replace-with-local-password

# Supabase Auth placeholders
SUPABASE_AUTH_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_AUTH_JWKS_URI=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
APP_SECURITY_ENABLED=false

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Payment references
PAYMENT_REFERENCE_PREFIX=TFR
